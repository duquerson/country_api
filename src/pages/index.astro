---
import BaseLayout from '../layouts/BaseLayout.astro';
import ListSearch from '@presentation/components/country/ListSearch.vue';
import SkeletonList from '@presentation/components/country/SkeletonList.astro';
import { getCountries } from '../core/di';

// SSR: Fetch initial data (Managed by Server Island)
const initialCountries = await getCountries.execute().catch(() => []);
---

<BaseLayout 
  title="Where in the world?"
  description="Search and explore countries from around the world. Filter by region, view detailed information, and discover borders."
>
  <ListSearch server:defer client:load initialData={initialCountries}>
    <SkeletonList slot="fallback" />
  </ListSearch>
</BaseLayout>