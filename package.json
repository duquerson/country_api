{
  "name": "country-api-hexagonal",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.6",
  "scripts": {
    "preinstall": "node -e \"const ua=process.env.npm_config_user_agent||''; if(!ua.includes('pnpm')){ console.error('ERROR: Use pnpm (detected '+ua+')'); process.exit(1);} \"",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e": "playwright test",
    "typecheck": "astro check",
    "lint": "eslint \"src/**/*.{ts,vue}\"",
    "lint:fix": "eslint \"src/**/*.{ts,vue}\" --fix"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.4",
    "@astrojs/vercel": "^10.0.4",
    "@astrojs/vue": "6.0.1",
    "@fontsource/nunito-sans": "5.2.7",
    "@heroicons/vue": "2.2.0",
    "astro": "6.1.3",
    "astro-icon": "1.1.5",
    "vue": "3.5.25",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.2.2",
    "@tailwindcss/vite": "4.2.2",
    "@types/node": "25.1.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-vue": "6.0.5",
    "@vue/test-utils": "2.4.6",
    "autoprefixer": "10.4.23",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "29.0.1",
    "postcss": "8.5.6",
    "tailwindcss": "4.2.2",
    "typescript": "5.6.3",
    "vite": "^7",
    "vitest": "^4.1.4",
    "vue-eslint-parser": "^10.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "vitest@>=3.0.0 <3.0.5": ">=3.0.5",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
      "vite@>=7.1.0 <=7.3.1": ">=7.3.2"
    }
  }
}